{
	"auto_append_newline": true,
	"auto_detect_indentation": true,
	"check_arguments_to_r_function_calls": true,
	"check_for_updates": false,
	"check_unexpected_assignment_in_function_call": true,
	"console_double_click_select": true,
	"default_encoding": "UTF-8",
	"editor_theme": "Solarized Dark",
	"enable_snippets": false,
	"highlight_r_function_calls": true,
	"highlight_selected_line": true,
	"highlight_selected_word": false,
	"initial_working_directory": "~",
	"insert_numbered_latex_sections": true,
	"jobs_tab_visibility": "closed",
	"latex_shell_escape": true,
	"load_workspace": false,
	"num_spaces_for_tab": 4,
	"rainbow_parentheses": true,
	"real_time_spellchecking": false,
	"reduced_motion": true,
	"reindent_on_paste": false,
	"rmd_viewer_type": "none",
	"save_workspace": "never",
	"show_diagnostics_other": true,
	"show_focus_rectangles": false,
	"show_indent_guides": true,
	"show_invisibles": true,
	"show_margin": false,
	"show_terminal_tab": false,
	"strip_trailing_whitespace": true,
	"style_diagnostics": true,
	"syntax_color_console": true,
	"use_spaces_for_tab": false,
	"use_tinytex": true,
	"vertically_align_arguments_indent": false,
	"warn_if_no_such_variable_in_scope": true,
	"warn_variable_defined_but_not_used": true,
	"wrap_tab_navigation": false,
	"panes": {
		"additional_source_columns": 0,
		"console_left_on_top": false,
		"console_right_on_top": false,
		"hiddenTabSet": [],
		"quadrants": [
			"TabSet1",
			"TabSet2",
			"Source",
			"Console"
		],
		"tabSet1": [
			"Environment",
			"Files",
			"Plots",
			"Packages",
			"Help",
			"VCS",
			"Presentation"
		],
		"tabSet2": [
			"History",
			"Connections",
			"Build",
			"Tutorial",
			"Viewer"
		]
	}
}
