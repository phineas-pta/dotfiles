{
	"agent": {
		"dock": "right"
	},
	"auto_install_extensions": {
		"catppuccin": true,
		"dockerfile": true,
		"html": true,
		"ini": true,
		"julia": true,
		"powershell": true,
		"quarto": true,
		"r": true,
		"rainbow-csv": true,
		"sql": true,
		"stan": true,
		"xml": true
	},
	"auto_update": false,
	"autosave": "on_focus_change",
	"buffer_font_family": "JuliaMono",
	"buffer_font_size": 14.0,
	"buffer_line_height": "standard",
	"calls": {
		"mute_on_join": true
	},
	"enable_language_server": false,
	"diagnostics": {
		"inline": {
			"enabled": true
		}
	},
	"drag_and_drop_selection": {
		"delay": 0
	},
	"formatter": "none",
	"git_panel": {
		"dock": "left",
	"show_count_badge": true,
		"file_icons": true
	},
	"hard_tabs": true,
	"hide_mouse": "never",
	"indent_guides": {
		"coloring": "indent_aware"
	},
	"inlay_hints": {
		"enabled": true
	},
	"line_indicator_format": "long",
	"message_editor": {
		"auto_replace_emoji_shortcode": false
	},
	"middle_click_paste": false,
	"minimap": {
		"show": "always"
	},
	"preferred_line_length": 120,
	"preview_tabs": {
		"enable_preview_from_file_finder": true
	},
	"project_panel": {
		"dock": "left",
		"git_status_indicator": true
	},
	"scroll_beyond_last_line": "off",
	"selection_highlight": false,
	"semantic_tokens": "combined",
	"session": {
		"trust_all_worktrees": true
	},
	"show_whitespaces": "all",
	"status_bar": {
		"active_encoding_button": "enabled",
		"line_endings_button": true
	},
	"tabs": {
		"file_icons": true,
		"git_status": true,
		"show_close_button": "always",
		"show_diagnostics": "all"
	},
	"terminal": {
		"blinking": "on",
		"copy_on_select": true,
		"cursor_shape": "bar",
		"font_features": {
			"calt": true
		},
		"show_count_badge": true
	},
	"theme": {
		"dark": "Catppuccin Macchiato",
		"light": "Catppuccin Latte",
		"mode": "system"
	},
	"title_bar": {
		"show_branch_status_icon": true,
		"show_sign_in": false
	},
	"toolbar": {
		"code_actions": true
	},
	"ui_font_size": 16,
	"use_on_type_format": false,
	"vim": {
		"cursor_shape": {
			"insert": "bar",
			"normal": "bar",
			"replace": "bar",
			"visual": "bar"
		},
		"default_mode": "insert"
	}
}
